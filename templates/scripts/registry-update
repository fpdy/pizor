#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

usage() {
  cat <<'EOF'
usage:
  registry-update status <pane-id> <status>
  registry-update report <pane-id> <status> [cleanup-required] [report-captured]
  registry-update captured <pane-id>
EOF
}

cmd="${1:-}"
case "$cmd" in
  status)
    registry_update_status "${2:?pane-id required}" "${3:?status required}"
    ;;
  report)
    registry_update_worker_report "${2:?pane-id required}" "${3:?status required}" "${4:-yes}" "${5:-no}"
    ;;
  captured)
    registry_mark_report_captured "${2:?pane-id required}"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac

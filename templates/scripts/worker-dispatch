#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

worker_pane="${1:?usage: worker-dispatch <worker-pane-id> <task-id> <assignment-id> <objective> [scope] [stop-condition] [do-not]}"
task_id="${2:?usage: worker-dispatch <worker-pane-id> <task-id> <assignment-id> <objective> [scope] [stop-condition] [do-not]}"
assignment_id="${3:?usage: worker-dispatch <worker-pane-id> <task-id> <assignment-id> <objective> [scope] [stop-condition] [do-not]}"
objective="${4:?usage: worker-dispatch <worker-pane-id> <task-id> <assignment-id> <objective> [scope] [stop-condition] [do-not]}"
scope="${5:-Stay within this assignment. Do not broaden scope.}"
stop_condition="${6:-Stop when you can produce the required report, or when you become blocked.}"
do_not="${7:-Do not commit. Do not modify unrelated files. Do not perform destructive actions.}"

master_pane="$(registry_get_role_pane master || true)"
observer_pane="$(registry_get_role_pane observer || true)"
[ -n "$master_pane" ] || die "no running master pane found in registry; start or register node-master before dispatch"
[ -n "$observer_pane" ] || die "no running observer pane found in registry; start or register node-observer before dispatch"

msg=$(cat <<EOF
/skill:node-worker

[MASTER_DISPATCH]
from_pane: ${master_pane}
to_pane: ${worker_pane}
role: worker
message_type: assignment
task_id: ${task_id}
assignment_id: ${assignment_id}
status: assigned

Routing:
- master_pane: ${master_pane}
- observer_pane: ${observer_pane}
- Store the full report in the sidecar report store using .pi/scripts/worker-report-submit when available.
- Ensure chat transport carries only WORKER_REPORT_POINTER to master_pane and observer_pane; worker-report-submit sends it automatically.
- Do not paste full WORKER_REPORT content into chat unless sidecar submission is unavailable.
- Do not send reports to the user/main thread or to hard-coded pane IDs.

Objective:
${objective}

Scope:
${scope}

Stop condition:
${stop_condition}

Do not:
${do_not}

Required report:
- summary
- files inspected
- files modified
- commands run
- findings
- blockers
- recommendation
- context_to_carry_forward
- context_to_discard

Before starting, create or identify a /tree checkpoint.
After finishing, write the full report to a local file and run:
.pi/scripts/worker-report-submit --master-pane ${master_pane} --observer-pane ${observer_pane} ${worker_pane} ${task_id} ${assignment_id} <status> <report-file>
The script sends WORKER_REPORT_POINTER to master_pane=${master_pane} and observer_pane=${observer_pane}; then wait for cleanup.
Do not report to the user/main thread.
[/MASTER_DISPATCH]
EOF
)

"$SCRIPT_DIR/pane-send" "$worker_pane" "$msg"
registry_update_status "$worker_pane" "assigned"

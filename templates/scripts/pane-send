#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

require_cmd zellij

pane_id="${1:?usage: pane-send <pane-id> <message>}"
message="${2:?usage: pane-send <pane-id> <message>}"

# Prefer Zellij's built-in terminal input actions over the external
# zellij-send-keys plugin. Wrap multi-line content in bracketed paste so Pi
# inserts it as one prompt instead of treating embedded newlines as keypresses.
zellij --session "$PI_ORCH_SESSION" action write-chars \
  --pane-id "$pane_id" \
  $'\e[200~'

zellij --session "$PI_ORCH_SESSION" action write-chars \
  --pane-id "$pane_id" \
  "$message"

zellij --session "$PI_ORCH_SESSION" action write-chars \
  --pane-id "$pane_id" \
  $'\e[201~'

# Press Enter after pasting the message.
zellij --session "$PI_ORCH_SESSION" action write-chars \
  --pane-id "$pane_id" \
  $'\r'

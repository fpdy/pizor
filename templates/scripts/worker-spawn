#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib.sh
source "$SCRIPT_DIR/lib.sh"

require_base_tools

task_id="${1:?usage: worker-spawn <task-id> <assignment-id> [purpose] [cwd]}"
assignment_id="${2:?usage: worker-spawn <task-id> <assignment-id> [purpose] [cwd]}"
purpose="${3:-bounded worker assignment}"
cwd="${4:-$PI_WORKDIR}"

pane_name="${PI_WORKER_NAME_PREFIX}-${task_id}-${assignment_id}"

pane_id="$(
  zellij --session "$PI_ORCH_SESSION" action new-pane \
    --cwd "$cwd" \
    --name "$pane_name" \
    -- "$PI_CMD"
)"

registry_add "worker" "$pane_id" "$task_id" "$assignment_id" "starting" "$purpose"

printf '%s\n' "$pane_id"

# Copy this file to .pi/.env and edit as needed.

# Zellij session name used by the orchestration scripts.
# Usually leave this unset: scripts default to the current Zellij session
# via $ZELLIJ_SESSION_NAME and must be run from inside Zellij.
# PI_ORCH_SESSION=multiagent-test

# Command used to start Pi.
PI_CMD=pi

# Path to zellij-send-keys plugin.
ZELLIJ_SEND_KEYS_PLUGIN="$HOME/.config/zellij/plugins/zellij-send-keys.wasm"

# Root directory where workers should start.
# Defaults to the repository root when unset.
# PI_WORKDIR="$PWD"

# Directory for local orchestration state.
PI_ORCH_STATE_DIR=".pizor"

# Prefix for dynamically spawned worker pane names.
PI_WORKER_NAME_PREFIX=worker

# Batch dispatch safety limits.
PI_MAX_PARALLEL_WORKERS=4
PI_MAX_PARALLEL_WRITERS=1

# Bounded startup synchronization before injecting startup prompts into newly
# created observer/master Pi panes. This is not lifecycle monitoring or polling.
PI_STARTUP_PROMPT_DELAY_SECONDS=2

# Bounded startup synchronization before dispatching prompts to newly spawned
# Pi worker panes. This is not lifecycle monitoring or polling. Non-numeric
# values fall back to 2; values above max are clamped.
PI_WORKER_STARTUP_PROMPT_DELAY_SECONDS=2
PI_WORKER_STARTUP_PROMPT_DELAY_MAX_SECONDS=10
